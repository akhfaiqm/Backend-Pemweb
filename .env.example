#
# Username HARUS berisi project ref, contoh: postgres.ibtjkiiinqaeikbqwbks
# Encode password spesial: & → %26, @ → %40

DATABASE_URL="postgresql://postgres.ibtjkiiinqaeikbqwbks:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.ibtjkiiinqaeikbqwbks:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Alias: jika di Railway cuma ada SUPABASE_DATABASE_URL (pooler 6543),
# DIRECT_URL akan dibuat otomatis dari DATABASE_URL saat start.
# SUPABASE_DATABASE_URL="(sama dengan DATABASE_URL di atas)"

