# Salin dari Supabase Dashboard → Connect → ORMs → Prisma
# https://supabase.com/dashboard/project/ibtjkiiinqaeikbqwbks?showConnect=true
#
# Penting:
# - Encode karakter khusus di password (mis. & → %26)
# - Di Windows, gunakan pooler (bukan db.*.supabase.co) jika muncul error P1001
# - Sesuaikan region pooler (aws-0-ap-southeast-1) dengan yang tampil di dashboard

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
